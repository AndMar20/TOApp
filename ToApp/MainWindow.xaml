<Window x:Class="ToApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Товары для дома — учет"
        Height="860"
        Width="1340"
        MinHeight="720"
        MinWidth="1160">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Padding="20,18">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Управление складом и документами" FontSize="26" FontWeight="Bold"/>
                    <TextBlock Text="Современное рабочее место: товары, справочники, поступления, продажи и остатки"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                    <Border Background="#FFDBEAFE" CornerRadius="999" Padding="10,4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Товаров: " FontSize="12" FontWeight="SemiBold" Foreground="#FF1D4ED8"/>
                            <TextBlock Text="{Binding ProductCount}" FontSize="12" FontWeight="SemiBold" Foreground="#FF1D4ED8"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFE0F2FE" CornerRadius="999" Padding="10,4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Поставщиков: " FontSize="12" FontWeight="SemiBold" Foreground="#FF0369A1"/>
                            <TextBlock Text="{Binding SupplierCount}" FontSize="12" FontWeight="SemiBold" Foreground="#FF0369A1"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#FFDCFCE7" CornerRadius="999" Padding="10,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Низкий остаток: " FontSize="12" FontWeight="SemiBold" Foreground="#FF166534"/>
                            <TextBlock Text="{Binding LowStockCount}" FontSize="12" FontWeight="SemiBold" Foreground="#FF166534"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Padding="10" Margin="0">
            <TabControl>
                <TabItem Header="Сводка">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="20,18">
                            <StackPanel>
                                <TextBlock Text="Товаров" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding ProductCount}" FontSize="40" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}" Padding="20,18">
                            <StackPanel>
                                <TextBlock Text="Поставщиков" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding SupplierCount}" FontSize="40" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="20,18">
                            <StackPanel>
                                <TextBlock Text="Низкий остаток" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding LowStockCount}" FontSize="40" FontWeight="Bold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Товары">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="14">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock Text="Поиск" VerticalAlignment="Center" Margin="0,0,8,0" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Width="320" Margin="0" Text="{Binding ProductSearch, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <DataGrid ItemsSource="{Binding Products}"
                                          SelectedItem="{Binding SelectedProduct}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="70"/>
                                        <DataGridTextColumn Header="Артикул" Binding="{Binding Sku}" Width="130"/>
                                        <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                                        <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinStockLevel}" Width="120"/>
                                        <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Padding="16">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <TextBlock Text="Карточка товара" Style="{StaticResource SectionTitleStyle}"/>

                                    <TextBlock Text="Артикул" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding ProductForm.Sku, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                                    <TextBlock Text="Наименование" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding ProductForm.ProductName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                                    <TextBlock Text="Категория" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding Categories}" SelectedValue="{Binding ProductForm.CategoryId, ValidatesOnDataErrors=True}" SelectedValuePath="CategoryId" DisplayMemberPath="CategoryName"/>

                                    <TextBlock Text="Ед. измерения" Style="{StaticResource FieldLabelStyle}"/>
                                    <ComboBox ItemsSource="{Binding Units}" SelectedValue="{Binding ProductForm.UnitId, ValidatesOnDataErrors=True}" SelectedValuePath="UnitId" DisplayMemberPath="UnitName"/>

                                    <TextBlock Text="Мин. остаток" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding ProductForm.MinStockLevel, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                                    <TextBlock Text="Описание" Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding ProductForm.Description, UpdateSourceTrigger=PropertyChanged}" Height="84" AcceptsReturn="True" TextWrapping="Wrap"/>

                                    <CheckBox IsChecked="{Binding ProductForm.IsActive}" Content="Товар активен" Margin="0,10,0,0"/>

                                    <UniformGrid Columns="3" Margin="0,16,0,0">
                                        <Button Content="Новый" Command="{Binding NewProductCommand}" Margin="0,0,8,0"/>
                                        <Button Content="Сохранить" Command="{Binding SaveProductCommand}" Margin="0,0,8,0"/>
                                        <Button Content="Деактивировать" Command="{Binding DeleteProductCommand}" Background="#FFDC2626"/>
                                    </UniformGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Справочники">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="Поставщики" Grid.Column="0">
                            <DockPanel>
                                <Button Content="Добавить" Command="{Binding AddSupplierCommand}" DockPanel.Dock="Bottom" Margin="0,10,0,0"/>
                                <ListBox ItemsSource="{Binding Suppliers}" DisplayMemberPath="SupplierName"/>
                            </DockPanel>
                        </GroupBox>

                        <GroupBox Header="Категории" Grid.Column="1">
                            <DockPanel>
                                <Button Content="Добавить" Command="{Binding AddCategoryCommand}" DockPanel.Dock="Bottom" Margin="0,10,0,0"/>
                                <ListBox ItemsSource="{Binding Categories}" DisplayMemberPath="CategoryName"/>
                            </DockPanel>
                        </GroupBox>

                        <GroupBox Header="Единицы измерения" Grid.Column="2">
                            <DockPanel>
                                <Button Content="Добавить" Command="{Binding AddUnitCommand}" DockPanel.Dock="Bottom" Margin="0,10,0,0"/>
                                <ListBox ItemsSource="{Binding Units}" DisplayMemberPath="UnitName"/>
                            </DockPanel>
                        </GroupBox>
                    </Grid>
                </TabItem>

                <TabItem Header="Поступление">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="12" Padding="16">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,12">
                                <TextBlock Text="Поставщик" Style="{StaticResource FieldLabelStyle}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox Width="320" Margin="0" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedReceiptSupplier}" DisplayMemberPath="SupplierName"/>
                                <Button Content="+ Строка" Command="{Binding AddReceiptLineCommand}" Margin="12,0,0,0" MinWidth="105"/>
                                <Button Content="- Строка" Command="{Binding RemoveReceiptLineCommand}" Margin="8,0,0,0" MinWidth="105" Background="#FF475569"/>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding ReceiptLines}" SelectedItem="{Binding SelectedReceiptLine}" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,0,0,12">
                                <DataGrid.Columns>
                                    <DataGridComboBoxColumn Header="Товар"
                                                            Width="*"
                                                            SelectedValueBinding="{Binding ProductId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                                            SelectedValuePath="ProductId"
                                                            DisplayMemberPath="ProductName"
                                                            ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <DataGridTextColumn Header="Количество" Width="140" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=N0, ValidatesOnDataErrors=True}"/>
                                    <DataGridTextColumn Header="Цена закупки" Width="160" Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged, StringFormat=N2, ValidatesOnDataErrors=True}"/>
                                    <DataGridTextColumn Header="Сумма" Width="140" IsReadOnly="True" Binding="{Binding Amount, StringFormat=N2}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Button Content="Провести поступление" Command="{Binding CreateReceiptCommand}" DockPanel.Dock="Bottom" Width="240" Height="38"/>
                        </DockPanel>
                    </Border>
                </TabItem>

                <TabItem Header="Продажа">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="12" Padding="16">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,12">
                                <Button Content="+ Строка" Command="{Binding AddSaleLineCommand}" MinWidth="105"/>
                                <Button Content="- Строка" Command="{Binding RemoveSaleLineCommand}" Margin="8,0,0,0" MinWidth="105" Background="#FF475569"/>
                            </StackPanel>

                            <DataGrid ItemsSource="{Binding SaleLines}" SelectedItem="{Binding SelectedSaleLine}" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,0,0,12">
                                <DataGrid.Columns>
                                    <DataGridComboBoxColumn Header="Товар"
                                                            Width="*"
                                                            SelectedValueBinding="{Binding ProductId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                                            SelectedValuePath="ProductId"
                                                            DisplayMemberPath="ProductName"
                                                            ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <DataGridTextColumn Header="Количество" Width="140" Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged, StringFormat=N0, ValidatesOnDataErrors=True}"/>
                                    <DataGridTextColumn Header="Цена продажи" Width="160" Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged, StringFormat=N2, ValidatesOnDataErrors=True}"/>
                                    <DataGridTextColumn Header="Сумма" Width="140" IsReadOnly="True" Binding="{Binding Amount, StringFormat=N2}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Button Content="Провести продажу" Command="{Binding CreateSaleCommand}" DockPanel.Dock="Bottom" Width="220" Height="38"/>
                        </DockPanel>
                    </Border>
                </TabItem>

                <TabItem Header="Остатки">
                    <Border Style="{StaticResource CardBorderStyle}" Margin="10" Padding="14">
                        <DockPanel>
                            <CheckBox Content="Показывать только товары с низким остатком"
                                      IsChecked="{Binding ShowOnlyLowStock}"
                                      DockPanel.Dock="Top"
                                      Margin="0,0,0,10"/>

                            <DataGrid ItemsSource="{Binding StockBalances}" SelectedItem="{Binding SelectedStockBalance}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Артикул" Binding="{Binding Sku}" Width="120"/>
                                    <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                                    <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="160"/>
                                    <DataGridTextColumn Header="Ед." Binding="{Binding UnitShortName}" Width="70"/>
                                    <DataGridTextColumn Header="Мин." Binding="{Binding MinStockLevel}" Width="80"/>
                                    <DataGridTextColumn Header="Остаток" Binding="{Binding CurrentStock}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</Window>
