<Window x:Class="ToApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Товары для дома — учет"
        Height="760" Width="1240" MinHeight="640" MinWidth="1100">
    <DockPanel Margin="12">
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}" />
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding IsBusy, StringFormat=Занят: {0}}" />
            </StatusBarItem>
        </StatusBar>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Обновить" Command="{Binding LoadCommand}" Padding="14,6" Margin="0,0,8,0"/>
            <TextBlock Text="Учет товаров хозяйственного магазина" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="17" Margin="0,0,20,0"/>
            <TextBlock Text="Поиск товара:" VerticalAlignment="Center"/>
            <TextBox Width="220" Margin="6,0,0,0" Text="{Binding ProductSearch, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

        <TabControl>
            <TabItem Header="Сводка">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="8" Background="#F3F7FF" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Товаров" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding ProductCount}" FontSize="34" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="8" Background="#F0FFF4" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Поставщиков" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SupplierCount}" FontSize="34" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Margin="8" Background="#FFF8E1" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Низкий остаток" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding LowStockCount}" FontSize="34" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Товары">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0"
                              ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="60"/>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Sku}" Width="120"/>
                            <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinStockLevel}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="2" Padding="12" BorderThickness="1" BorderBrush="#DDD" CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="Карточка товара" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
                            <TextBlock Text="Артикул"/>
                            <TextBox Text="{Binding ProductForm.Sku, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                            <TextBlock Text="Наименование" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding ProductForm.ProductName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                            <TextBlock Text="Категория" Margin="0,8,0,0"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedValue="{Binding ProductForm.CategoryId, ValidatesOnDataErrors=True}" SelectedValuePath="CategoryId" DisplayMemberPath="CategoryName"/>
                            <TextBlock Text="Ед. измерения" Margin="0,8,0,0"/>
                            <ComboBox ItemsSource="{Binding Units}" SelectedValue="{Binding ProductForm.UnitId, ValidatesOnDataErrors=True}" SelectedValuePath="UnitId" DisplayMemberPath="UnitName"/>
                            <TextBlock Text="Мин. остаток" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding ProductForm.MinStockLevel, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
                            <TextBlock Text="Описание" Margin="0,8,0,0"/>
                            <TextBox Text="{Binding ProductForm.Description, UpdateSourceTrigger=PropertyChanged}" Height="70" AcceptsReturn="True"/>
                            <CheckBox IsChecked="{Binding ProductForm.IsActive}" Content="Активен" Margin="0,8,0,0"/>

                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Content="Новый" Command="{Binding NewProductCommand}" Padding="10,5" Margin="0,0,8,0"/>
                                <Button Content="Сохранить" Command="{Binding SaveProductCommand}" Padding="10,5" Margin="0,0,8,0"/>
                                <Button Content="Удалить" Command="{Binding DeleteProductCommand}" Padding="10,5"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Справочники">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Поставщики" Margin="6" Grid.Column="0">
                        <DockPanel>
                            <Button Content="Добавить" Command="{Binding AddSupplierCommand}" DockPanel.Dock="Bottom" Margin="0,8,0,0"/>
                            <ListBox ItemsSource="{Binding Suppliers}" DisplayMemberPath="SupplierName"/>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="Категории" Margin="6" Grid.Column="1">
                        <DockPanel>
                            <Button Content="Добавить" Command="{Binding AddCategoryCommand}" DockPanel.Dock="Bottom" Margin="0,8,0,0"/>
                            <ListBox ItemsSource="{Binding Categories}" DisplayMemberPath="CategoryName"/>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="Единицы измерения" Margin="6" Grid.Column="2">
                        <DockPanel>
                            <Button Content="Добавить" Command="{Binding AddUnitCommand}" DockPanel.Dock="Bottom" Margin="0,8,0,0"/>
                            <ListBox ItemsSource="{Binding Units}" DisplayMemberPath="UnitName"/>
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Поступление">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Поставщик"/>
                        <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedReceiptSupplier}" DisplayMemberPath="SupplierName"/>
                        <TextBlock Text="Товар" Margin="0,8,0,0"/>
                        <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding LineReceiptProduct}" DisplayMemberPath="ProductName"/>
                        <TextBlock Text="Количество" Margin="0,8,0,0"/>
                        <TextBox Text="{Binding LineReceiptQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Цена закупки" Margin="0,8,0,0"/>
                        <TextBox Text="{Binding LineReceiptPrice, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Добавить строку" Command="{Binding AddReceiptLineCommand}" Margin="0,10,0,0" Padding="10,6"/>
                        <Button Content="Провести поступление" Command="{Binding CreateReceiptCommand}" Margin="0,8,0,0" Padding="12,7"/>
                        <TextBlock Text="{Binding ReceiptTotal, StringFormat=Итого: {0:C}}" FontWeight="Bold" Margin="0,12,0,0"/>
                    </StackPanel>

                    <DockPanel Grid.Column="2">
                        <Button DockPanel.Dock="Bottom" Content="Удалить выбранную строку" Command="{Binding RemoveReceiptLineCommand}" Margin="0,8,0,0" Padding="10,6"/>
                        <DataGrid ItemsSource="{Binding ReceiptLines}" SelectedItem="{Binding SelectedReceiptLine}" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="100"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="120"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Продажа">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Товар"/>
                        <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding LineSaleProduct}" DisplayMemberPath="ProductName"/>
                        <TextBlock Text="Количество" Margin="0,8,0,0"/>
                        <TextBox Text="{Binding LineSaleQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Цена продажи" Margin="0,8,0,0"/>
                        <TextBox Text="{Binding LineSalePrice, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Content="Добавить строку" Command="{Binding AddSaleLineCommand}" Margin="0,10,0,0" Padding="10,6"/>
                        <Button Content="Провести продажу" Command="{Binding CreateSaleCommand}" Margin="0,8,0,0" Padding="12,7"/>
                        <TextBlock Text="{Binding SaleTotal, StringFormat=Итого: {0:C}}" FontWeight="Bold" Margin="0,12,0,0"/>
                    </StackPanel>

                    <DockPanel Grid.Column="2">
                        <Button DockPanel.Dock="Bottom" Content="Удалить выбранную строку" Command="{Binding RemoveSaleLineCommand}" Margin="0,8,0,0" Padding="10,6"/>
                        <DataGrid ItemsSource="{Binding SaleLines}" SelectedItem="{Binding SelectedSaleLine}" AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Товар" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Кол-во" Binding="{Binding Quantity}" Width="100"/>
                                <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="120"/>
                                <DataGridTextColumn Header="Сумма" Binding="{Binding Amount}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Остатки">
                <DockPanel Margin="10">
                    <CheckBox Content="Показывать только товары с низким остатком"
                              IsChecked="{Binding ShowOnlyLowStock}"
                              DockPanel.Dock="Top"
                              Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding StockBalances}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Sku}" Width="120"/>
                            <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="160"/>
                            <DataGridTextColumn Header="Ед." Binding="{Binding UnitShortName}" Width="70"/>
                            <DataGridTextColumn Header="Мин." Binding="{Binding MinStockLevel}" Width="80"/>
                            <DataGridTextColumn Header="Остаток" Binding="{Binding CurrentStock}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
