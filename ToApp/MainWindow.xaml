<Window x:Class="ToApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Товары для дома — учет" Height="760" Width="1200" MinHeight="640" MinWidth="1050">
    <DockPanel Margin="16">
        <Border DockPanel.Dock="Top" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,10">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Учет товаров хозяйственного магазина" FontWeight="SemiBold" FontSize="21"/>
                    <TextBlock Text="Склад, поступления и продажи в едином интерфейсе" Foreground="{StaticResource TextMutedBrush}" Margin="0,3,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TabControl>
            <TabItem Header="Сводка">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Товаров" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding ProductCount}" FontSize="34" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Поставщиков" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding SupplierCount}" FontSize="34" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Низкий остаток" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextMutedBrush}"/>
                            <TextBlock Text="{Binding LowStockCount}" FontSize="34" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Товары">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <DataGrid Grid.Column="0"
                              ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="60"/>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Sku}" Width="120"/>
                            <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Мин. остаток" Binding="{Binding MinStockLevel}" Width="120"/>
                            <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Карточка товара" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="Артикул" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding SelectedProduct.Sku, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Наименование" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding SelectedProduct.ProductName, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Категория" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedValue="{Binding SelectedProduct.CategoryId}" SelectedValuePath="CategoryId" DisplayMemberPath="CategoryName"/>
                            <TextBlock Text="Ед. измерения" Style="{StaticResource FieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Units}" SelectedValue="{Binding SelectedProduct.UnitId}" SelectedValuePath="UnitId" DisplayMemberPath="UnitName"/>
                            <TextBlock Text="Мин. остаток" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding SelectedProduct.MinStockLevel, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Описание" Style="{StaticResource FieldLabelStyle}"/>
                            <TextBox Text="{Binding SelectedProduct.Description, UpdateSourceTrigger=PropertyChanged}" Height="70" AcceptsReturn="True"/>
                            <CheckBox IsChecked="{Binding SelectedProduct.IsActive}" Content="Активен" Margin="0,8,0,0"/>

                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Button Content="Новый" Command="{Binding NewProductCommand}" Margin="0,0,8,0"/>
                                <Button Content="Сохранить" Command="{Binding SaveProductCommand}" Margin="0,0,8,0"/>
                                <Button Content="Удалить" Command="{Binding DeleteProductCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Справочники">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Поставщики" Margin="6" Grid.Column="0">
                        <DockPanel>
                            <Button Content="Добавить" Command="{Binding AddSupplierCommand}" DockPanel.Dock="Bottom" Margin="0,8,0,0"/>
                            <ListBox ItemsSource="{Binding Suppliers}" DisplayMemberPath="SupplierName"/>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="Категории" Margin="6" Grid.Column="1">
                        <DockPanel>
                            <Button Content="Добавить" Command="{Binding AddCategoryCommand}" DockPanel.Dock="Bottom" Margin="0,8,0,0"/>
                            <ListBox ItemsSource="{Binding Categories}" DisplayMemberPath="CategoryName"/>
                        </DockPanel>
                    </GroupBox>

                    <GroupBox Header="Единицы измерения" Margin="6" Grid.Column="2">
                        <DockPanel>
                            <Button Content="Добавить" Command="{Binding AddUnitCommand}" DockPanel.Dock="Bottom" Margin="0,8,0,0"/>
                            <ListBox ItemsSource="{Binding Units}" DisplayMemberPath="UnitName"/>
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Поступление">
                <Border Style="{StaticResource CardBorderStyle}" Margin="16" MaxWidth="500">
                <StackPanel>
                    <TextBlock Text="Поставщик"/>
                    <ComboBox ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedReceiptSupplier}" DisplayMemberPath="SupplierName"/>
                    <TextBlock Text="Товар" Style="{StaticResource FieldLabelStyle}"/>
                    <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedReceiptProduct}" DisplayMemberPath="ProductName"/>
                    <TextBlock Text="Количество" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding ReceiptQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Цена закупки" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding ReceiptPrice, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Провести поступление" Command="{Binding CreateReceiptCommand}" Margin="0,14,0,0"/>
                </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Продажа">
                <Border Style="{StaticResource CardBorderStyle}" Margin="16" MaxWidth="500">
                <StackPanel>
                    <TextBlock Text="Товар"/>
                    <ComboBox ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedSaleProduct}" DisplayMemberPath="ProductName"/>
                    <TextBlock Text="Количество" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding SaleQuantity, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Text="Цена продажи" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding SalePrice, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="Провести продажу" Command="{Binding CreateSaleCommand}" Margin="0,14,0,0"/>
                </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Остатки">
                <DockPanel Margin="10">
                    <CheckBox Content="Показывать только товары с низким остатком"
                              IsChecked="{Binding ShowOnlyLowStock}"
                              DockPanel.Dock="Top"
                              Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding StockBalances}" SelectedItem="{Binding SelectedStockBalance}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Артикул" Binding="{Binding Sku}" Width="120"/>
                            <DataGridTextColumn Header="Наименование" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="160"/>
                            <DataGridTextColumn Header="Ед." Binding="{Binding UnitShortName}" Width="70"/>
                            <DataGridTextColumn Header="Мин." Binding="{Binding MinStockLevel}" Width="80"/>
                            <DataGridTextColumn Header="Остаток" Binding="{Binding CurrentStock}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
